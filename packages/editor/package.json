  "keywords": [
    "verona",
    "verona-spec-3.5.0",
    "editor",
    "interface"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@verona/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  }
}